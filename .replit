entrypoint = "index.js"
modules = ["bun-1.1", "nodejs-20", "nodejs-22", "python-3.11"]
hidden = [".config", "package-lock.json"]

[gitHubImport]
requiredFiles = [".replit", "replit.nix", "package.json", "package-lock.json"]

[nix]
channel = "stable-24_11"
packages = ["bottom", "fish", "ksh", "libxcrypt", "nodejs_22", "perl540Packages.AppClusterSSH", "powershell", "python311Packages.pipx", "python312Packages.pip", "zsh"]

[deployment]
run = ["node", "index.js"]
deploymentTarget = "autoscale"
ignorePorts = false

[agent]
expertMode = true

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000

[packaging]
includePackage = "fastapi>=0.100.0"
includePackage = "uvicorn[standard]>=0.20.0"
includePackage = "pydantic>=2.0.0"
includePackage = "PyJWT>=2.0.0"
includePackage = "python-multipart>=0.0.6"
includePackage = "cryptography>=41.0.0"
includePackage = "aiofiles>=23.0.0"

[[ports]]
localPort = 5000
externalPort = 80
